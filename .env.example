# ============================================================
# Dashboard Doodstream — Environment Variables
# Copy file ini ke .env.local lalu isi values, atau paste ke Vercel
# Settings → Environment Variables (Bulk Edit)
# ============================================================

# ====== SUPABASE (REQUIRED) ======
# Dapat dari: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ====== POSTGRES DIRECT CONNECTION (REQUIRED) ======
# Dapat dari: Supabase → Settings → Database → Connection Pooling
# WAJIB pakai pooler port 6543 (bukan 5432 langsung)
PG_HOST=aws-1-region.pooler.supabase.com
PG_PORT=6543
PG_DATABASE=postgres
PG_USER=postgres.your_project_ref
PG_PASSWORD=your_db_password_here

# ====== CRON SECRET (REQUIRED) ======
# Generate random string: openssl rand -base64 32
# Pakai value yang sama di kedua var
CRON_SECRET=generate_random_32_char_string_here
NEXT_PUBLIC_CRON_SECRET=same_as_CRON_SECRET_above

# ====== TWITTER API v2 (REQUIRED untuk Auto Post Twitter) ======
# Dapat dari: https://developer.twitter.com/en/portal/projects-and-apps
# Bikin App baru → User authentication settings:
#   - OAuth 2.0: ON
#   - Type: Confidential client
#   - App permissions: Read and write
#   - Callback URL: https://your-domain.com/api/twitter/callback
TWITTER_CLIENT_ID=your_client_id
TWITTER_CLIENT_SECRET=your_client_secret
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_CALLBACK_URL=https://your-domain.com/api/twitter/callback
